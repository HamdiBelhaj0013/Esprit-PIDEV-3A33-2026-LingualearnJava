<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.UserController"
      spacing="0" style="-fx-background-color:#f5f5f5;">

  <HBox style="-fx-background-color:#1D9E75;-fx-padding:12 20;" alignment="CENTER_LEFT">
    <Label text="LinguaLearn — Mon espace" style="-fx-text-fill:white;-fx-font-size:15;-fx-font-weight:bold;"/>
  </HBox>

  <TabPane VBox.vgrow="ALWAYS">

    <Tab text="Mes Réclamations" closable="false">
      <VBox spacing="12" style="-fx-padding:14;">

        <VBox style="-fx-background-color:white;-fx-border-color:#e0e0e0;-fx-border-width:0.5;-fx-border-radius:8;-fx-background-radius:8;-fx-padding:14;" spacing="8">
          <Label text="Nouvelle réclamation" style="-fx-font-weight:bold;-fx-text-fill:#555;"/>
          <HBox spacing="10">
            <TextField fx:id="subjectField" promptText="Sujet *" HBox.hgrow="ALWAYS"
                       style="-fx-border-radius:6;-fx-background-radius:6;-fx-border-color:#ddd;-fx-padding:8;"/>
            <ComboBox fx:id="priorityBox" promptText="Priorité *" prefWidth="130"/>
          </HBox>
          <TextArea fx:id="messageField" promptText="Votre message *" prefHeight="75" wrapText="true"
                    style="-fx-border-radius:6;-fx-background-radius:6;-fx-border-color:#ddd;-fx-padding:8;"/>
          <HBox spacing="8">
            <Button text="Soumettre" onAction="#soumettre"
                    style="-fx-background-color:#1D9E75;-fx-text-fill:white;-fx-font-weight:bold;-fx-border-radius:6;-fx-background-radius:6;-fx-padding:8 18;"/>
            <Button text="Charger pour modifier" onAction="#chargerPourModif"
                    style="-fx-background-color:#E6F1FB;-fx-text-fill:#185FA5;-fx-font-weight:bold;-fx-border-radius:6;-fx-background-radius:6;-fx-padding:8 14;"/>
            <Button text="Enregistrer modif" onAction="#modifier"
                    style="-fx-background-color:#FAEEDA;-fx-text-fill:#633806;-fx-font-weight:bold;-fx-border-radius:6;-fx-background-radius:6;-fx-padding:8 14;"/>
            <Button text="Supprimer" onAction="#supprimer"
                    style="-fx-background-color:#FCEBEB;-fx-text-fill:#A32D2D;-fx-font-weight:bold;-fx-border-radius:6;-fx-background-radius:6;-fx-padding:8 14;"/>
            <Button text="Actualiser" onAction="#chargerReclamations"
                    style="-fx-background-color:#f0f0f0;-fx-text-fill:#555;-fx-border-radius:6;-fx-background-radius:6;-fx-padding:8 14;"/>
          </HBox>
          <Label fx:id="reclMsg"/>
          <Label text="* Modifier / Supprimer uniquement si statut = PENDING"
                 style="-fx-text-fill:#aaa;-fx-font-size:11;"/>
        </VBox>

        <VBox style="-fx-background-color:white;-fx-border-color:#e0e0e0;-fx-border-width:0.5;-fx-border-radius:8;-fx-background-radius:8;">
          <TableView fx:id="reclTable" prefHeight="230" style="-fx-border-color:transparent;">
            <columns>
              <TableColumn fx:id="rColId" text="ID" prefWidth="45"/>
              <TableColumn fx:id="rColSubject" text="Sujet" prefWidth="200"/>
              <TableColumn fx:id="rColStatus" text="Statut" prefWidth="120"/>
              <TableColumn fx:id="rColPriority" text="Priorité" prefWidth="90"/>
              <TableColumn fx:id="rColDate" text="Date" prefWidth="160"/>
            </columns>
            <placeholder><Label text="Aucune réclamation." style="-fx-text-fill:#aaa;"/></placeholder>
          </TableView>
        </VBox>
      </VBox>
    </Tab>

    <Tab text="FAQ" closable="false">
      <VBox spacing="10" style="-fx-padding:14;">
        <HBox spacing="8" alignment="CENTER_LEFT">
          <Label text="Questions fréquentes" style="-fx-font-size:14;-fx-font-weight:bold;"/>
          <Region HBox.hgrow="ALWAYS"/>
          <TextField fx:id="faqSearch" promptText="Rechercher..." prefWidth="200"
                     style="-fx-border-radius:6;-fx-background-radius:6;-fx-border-color:#ddd;-fx-padding:7;"/>
          <Button text="Rechercher" onAction="#rechercherFAQ"
                  style="-fx-background-color:#534AB7;-fx-text-fill:white;-fx-border-radius:6;-fx-background-radius:6;-fx-padding:7 14;"/>
          <Button text="Tout voir" onAction="#chargerFAQ"
                  style="-fx-background-color:#f0f0f0;-fx-text-fill:#555;-fx-border-radius:6;-fx-background-radius:6;-fx-padding:7 12;"/>
        </HBox>
        <VBox style="-fx-background-color:white;-fx-border-color:#e0e0e0;-fx-border-width:0.5;-fx-border-radius:8;-fx-background-radius:8;">
          <TableView fx:id="faqTable" prefHeight="380" style="-fx-border-color:transparent;">
            <columns>
              <TableColumn fx:id="fColQuestion" text="Question" prefWidth="280"/>
              <TableColumn fx:id="fColAnswer" text="Réponse" prefWidth="300"/>
              <TableColumn fx:id="fColCategory" text="Catégorie" prefWidth="120"/>
            </columns>
            <placeholder><Label text="Aucune FAQ." style="-fx-text-fill:#aaa;"/></placeholder>
          </TableView>
        </VBox>
      </VBox>
    </Tab>

  </TabPane>
</VBox>
