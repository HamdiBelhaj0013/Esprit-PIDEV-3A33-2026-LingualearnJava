<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.AdminController"
      spacing="0" style="-fx-background-color:#f5f5f5;">

  <HBox style="-fx-background-color:#534AB7;-fx-padding:12 20;" alignment="CENTER_LEFT">
    <Label text="LinguaLearn — Administration" style="-fx-text-fill:white;-fx-font-size:15;-fx-font-weight:bold;"/>
    <Region HBox.hgrow="ALWAYS"/>
    <Button text="Gérer les FAQ" onAction="#ouvrirGestionFAQ"
            style="-fx-background-color:#EEEDFE;-fx-text-fill:#3C3489;-fx-font-weight:bold;-fx-border-radius:6;-fx-background-radius:6;-fx-padding:7 14;"/>
  </HBox>

  <HBox spacing="10" style="-fx-padding:12 16;-fx-background-color:white;-fx-border-color:#e0e0e0;-fx-border-width:0 0 0.5 0;">
    <VBox style="-fx-background-color:#f5f5f5;-fx-background-radius:8;-fx-padding:10 16;" HBox.hgrow="ALWAYS">
      <Label text="Total" style="-fx-font-size:11;-fx-text-fill:#888;"/>
      <Label fx:id="statTotal" text="—" style="-fx-font-size:22;-fx-font-weight:bold;"/>
    </VBox>
    <VBox style="-fx-background-color:#FAEEDA;-fx-background-radius:8;-fx-padding:10 16;" HBox.hgrow="ALWAYS">
      <Label text="En attente" style="-fx-font-size:11;-fx-text-fill:#854F0B;"/>
      <Label fx:id="statPending" text="—" style="-fx-font-size:22;-fx-font-weight:bold;-fx-text-fill:#633806;"/>
    </VBox>
    <VBox style="-fx-background-color:#EAF3DE;-fx-background-radius:8;-fx-padding:10 16;" HBox.hgrow="ALWAYS">
      <Label text="Résolues" style="-fx-font-size:11;-fx-text-fill:#3B6D11;"/>
      <Label fx:id="statResolved" text="—" style="-fx-font-size:22;-fx-font-weight:bold;-fx-text-fill:#27500A;"/>
    </VBox>
  </HBox>

  <VBox spacing="12" style="-fx-padding:14;" VBox.vgrow="ALWAYS">

    <HBox spacing="8" alignment="CENTER_LEFT">
      <ComboBox fx:id="filtreStatut" promptText="Filtrer par statut" prefWidth="160"/>
      <Button text="Filtrer" onAction="#filtrer"
              style="-fx-background-color:#534AB7;-fx-text-fill:white;-fx-font-weight:bold;-fx-border-radius:6;-fx-background-radius:6;-fx-padding:7 16;"/>
      <Button text="Tout voir" onAction="#charger"
              style="-fx-background-color:#f0f0f0;-fx-text-fill:#555;-fx-border-radius:6;-fx-background-radius:6;-fx-padding:7 14;"/>
    </HBox>

    <VBox style="-fx-background-color:white;-fx-border-color:#e0e0e0;-fx-border-width:0.5;-fx-border-radius:8;-fx-background-radius:8;">
      <TableView fx:id="reclTable" prefHeight="190" style="-fx-border-color:transparent;">
        <columns>
          <TableColumn fx:id="rColId" text="ID" prefWidth="45"/>
          <TableColumn fx:id="rColSubject" text="Sujet" prefWidth="185"/>
          <TableColumn fx:id="rColStatus" text="Statut" prefWidth="115"/>
          <TableColumn fx:id="rColPriority" text="Priorité" prefWidth="85"/>
          <TableColumn fx:id="rColUser" text="User ID" prefWidth="70"/>
          <TableColumn fx:id="rColDate" text="Date" prefWidth="145"/>
        </columns>
        <placeholder><Label text="Aucune réclamation." style="-fx-text-fill:#aaa;"/></placeholder>
      </TableView>
      <HBox spacing="8" style="-fx-padding:10 12;-fx-border-color:#e0e0e0;-fx-border-width:0.5 0 0 0;">
        <ComboBox fx:id="statutBox" promptText="Nouveau statut" prefWidth="155"/>
        <Button text="Changer statut" onAction="#changerStatut"
                style="-fx-background-color:#EEEDFE;-fx-text-fill:#3C3489;-fx-font-weight:bold;-fx-border-radius:6;-fx-background-radius:6;-fx-padding:7 14;"/>
        <Button text="Supprimer" onAction="#supprimer"
                style="-fx-background-color:#FCEBEB;-fx-text-fill:#A32D2D;-fx-font-weight:bold;-fx-border-radius:6;-fx-background-radius:6;-fx-padding:7 14;"/>
      </HBox>
    </VBox>

    <VBox style="-fx-background-color:white;-fx-border-color:#e0e0e0;-fx-border-width:0.5;-fx-border-radius:8;-fx-background-radius:8;-fx-padding:14;" spacing="8">
      <Label text="Répondre à la réclamation sélectionnée" style="-fx-font-weight:bold;-fx-text-fill:#555;"/>
      <TextArea fx:id="reponseField" promptText="Votre réponse..." prefHeight="65" wrapText="true"
                style="-fx-border-radius:6;-fx-background-radius:6;-fx-border-color:#ddd;-fx-padding:8;"/>
      <Button text="Envoyer" onAction="#envoyerReponse"
              style="-fx-background-color:#1D9E75;-fx-text-fill:white;-fx-font-weight:bold;-fx-border-radius:6;-fx-background-radius:6;-fx-padding:8 18;"/>
      <Label fx:id="reponseMsg"/>
      <Label text="Historique" style="-fx-font-size:11;-fx-font-weight:bold;-fx-text-fill:#888;"/>
      <ListView fx:id="reponsesList" prefHeight="80" style="-fx-font-size:12;"/>
    </VBox>

  </VBox>
</VBox>
