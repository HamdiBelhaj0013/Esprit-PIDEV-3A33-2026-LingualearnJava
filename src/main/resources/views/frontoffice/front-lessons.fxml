<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/23.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.controllers.FrontLessonsController"
            style="-fx-background-color: #eef2ff;">

    <!-- ===== MAIN CONTENT ===== -->
    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true" hbarPolicy="NEVER"
                    styleClass="front-page-root">
            <content>
                <VBox styleClass="player-shell" alignment="TOP_CENTER" spacing="20">
                    <VBox maxWidth="820" spacing="18" VBox.vgrow="ALWAYS">

                        <!-- Back link -->
                        <Label fx:id="backToCoursesLabel"
                               text="← Back to courses"
                               styleClass="link-label"/>

                        <!-- Progress card -->
                        <VBox style="-fx-background-color:#ffffff;
                                     -fx-background-radius:14;
                                     -fx-border-color:#e2e8f0;
                                     -fx-border-radius:14;
                                     -fx-padding:14 20;
                                     -fx-effect:dropshadow(gaussian,rgba(15,23,42,0.06),10,0,0,2);"
                              spacing="10">
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <Label fx:id="courseTitle"
                                       styleClass="player-top-title"
                                       HBox.hgrow="ALWAYS"/>
                                <Label fx:id="progressText"
                                       styleClass="player-progress-text"/>
                            </HBox>
                            <ProgressBar fx:id="lessonProgressBar"
                                         maxWidth="Infinity"
                                         prefHeight="7"
                                         progress="0.0"/>
                        </VBox>

                        <!-- Step tabs — full width pill row -->
                        <HBox spacing="4"
                              style="-fx-background-color:#ffffff;
                                     -fx-background-radius:12;
                                     -fx-border-color:#e2e8f0;
                                     -fx-border-radius:12;
                                     -fx-padding:5;
                                     -fx-effect:dropshadow(gaussian,rgba(15,23,42,0.05),8,0,0,1);">
                            <Button fx:id="btnReadTab"
                                    text="📖  Read"
                                    styleClass="player-step-tab player-step-tab-active"
                                    maxWidth="Infinity"
                                    HBox.hgrow="ALWAYS"/>
                            <Button fx:id="btnVocabTab"
                                    text="🔤  Vocab"
                                    styleClass="player-step-tab"
                                    maxWidth="Infinity"
                                    HBox.hgrow="ALWAYS"/>
                            <Button fx:id="btnQuizTab"
                                    text="🧩  Quiz"
                                    styleClass="player-step-tab"
                                    maxWidth="Infinity"
                                    HBox.hgrow="ALWAYS"/>
                            <Button fx:id="btnDoneTab"
                                    text="✅  Done"
                                    styleClass="player-step-tab"
                                    maxWidth="Infinity"
                                    HBox.hgrow="ALWAYS"/>
                        </HBox>

                        <!-- Dynamic content -->
                        <StackPane fx:id="contentHolder"
                                   minHeight="380"
                                   VBox.vgrow="ALWAYS"
                                   style="-fx-background-color:transparent;"/>

                    </VBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>

    <!-- ===== RIGHT SIDEBAR — compact ===== -->
    <right>
        <VBox prefWidth="190" minWidth="170"
              style="-fx-background-color:#ffffff;
                     -fx-border-color:#e2e8f0;
                     -fx-border-width: 0 0 0 1;">
            <padding>
                <Insets top="22" right="14" bottom="20" left="14"/>
            </padding>

            <!-- Steps -->
            <Label text="IN THIS LESSON" styleClass="side-title"/>

            <Button fx:id="sideReadButton"
                    text="📖  Reading"
                    styleClass="side-step side-step-active"
                    maxWidth="Infinity"/>
            <Button fx:id="sideVocabButton"
                    text="🔤  Vocabulary"
                    styleClass="side-step"
                    maxWidth="Infinity"/>
            <Button fx:id="sideQuizButton"
                    text="🧩  Quick Quiz"
                    styleClass="side-step"
                    maxWidth="Infinity"/>
            <Button fx:id="sideDoneButton"
                    text="✅  Complete"
                    styleClass="side-step"
                    maxWidth="Infinity"/>

            <Region VBox.vgrow="ALWAYS"/>

            <!-- XP box -->
            <VBox spacing="6"
                  style="-fx-background-color:#fffbeb;
                         -fx-background-radius:12;
                         -fx-border-color:#fde68a;
                         -fx-border-radius:12;
                         -fx-padding:14 14;">
                <Label text="XP REWARD"
                       style="-fx-font-size:10px; -fx-font-weight:bold; -fx-text-fill:#92400e;"/>
                <Label fx:id="xpRewardLabel" styleClass="xp-badge"/>
                <Label text="Complete all steps to earn XP"
                       wrapText="true"
                       style="-fx-font-size:11px; -fx-text-fill:#92400e;"/>
            </VBox>

        </VBox>
    </right>

</BorderPane>
