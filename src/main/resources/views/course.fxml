<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.controllers.CourseController"
            fitToWidth="true"
            fitToHeight="true"
            hbarPolicy="NEVER"
            styleClass="scroll-pane">

    <content>
        <VBox spacing="20" styleClass="page-container" VBox.vgrow="ALWAYS">
            <padding>
                <Insets top="24" right="28" bottom="28" left="28"/>
            </padding>

            <!-- ===== BREADCRUMB ===== -->
            <HBox styleClass="breadcrumb-bar" spacing="4">
                <Label text="Dashboard" styleClass="breadcrumb-item"/>
                <Label text="/" styleClass="breadcrumb-sep"/>
                <Label text="Pedagogical Content" styleClass="breadcrumb-item"/>
                <Label text="/" styleClass="breadcrumb-sep"/>
                <Label text="Courses" styleClass="breadcrumb-item-active"/>
            </HBox>

            <!-- ===== PAGE HEADER ===== -->
            <HBox alignment="CENTER_LEFT" spacing="12">
                <VBox spacing="3">
                    <Label text="Courses" styleClass="page-title"/>
                    <Label text="Manage all learning courses" styleClass="page-subtitle"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="+ New Course" onAction="#showAddCourseForm" styleClass="btn-primary"/>
            </HBox>

            <!-- ===== FORM PANEL ===== -->
            <VBox fx:id="formPanel" styleClass="form-panel" spacing="14" managed="false" visible="false">
                <HBox alignment="CENTER_LEFT">
                    <Label fx:id="formPanelTitle" text="Add New Course" styleClass="form-panel-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="✕" onAction="#hideForm" styleClass="btn-secondary"/>
                </HBox>

                <Separator/>

                <VBox spacing="4">
                    <Label text="Course Title" styleClass="form-label"/>
                    <TextField fx:id="txtTitle" promptText="e.g. Introduction to French"/>
                </VBox>

                <HBox spacing="16">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Level" styleClass="form-label"/>
                        <ComboBox fx:id="cbLevel" promptText="Select level" maxWidth="Infinity"/>
                    </VBox>
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Status" styleClass="form-label"/>
                        <ComboBox fx:id="cbStatus" promptText="Select status" maxWidth="Infinity"/>
                    </VBox>
                </HBox>

                <HBox spacing="16">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Published Date" styleClass="form-label"/>
                        <DatePicker fx:id="dpPublishedAt" maxWidth="Infinity"/>
                    </VBox>
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Author ID (optional)" styleClass="form-label"/>
                        <TextField fx:id="txtAuthorId" promptText="e.g. 1"/>
                    </VBox>
                </HBox>

                <VBox spacing="4">
                    <Label text="Language" styleClass="form-label"/>
                    <ComboBox fx:id="cbLanguage" promptText="Select language" maxWidth="Infinity"/>
                </VBox>

                <HBox spacing="10">
                    <Button text="💾  Add Course" onAction="#addCourse" styleClass="btn-success"/>
                    <Button text="✏  Update" onAction="#updateCourse" styleClass="btn-warning"/>
                    <Button text="🗑  Delete" onAction="#deleteCourse" styleClass="btn-danger"/>
                    <Button text="Reset" onAction="#resetForm" styleClass="btn-secondary"/>
                </HBox>
            </VBox>

            <!-- ===== SEARCH BAR ===== -->
            <VBox styleClass="search-bar-box">
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <TextField fx:id="txtSearchCourse" promptText="🔍  Course title..." HBox.hgrow="ALWAYS"/>
                    <ComboBox fx:id="cbFilterLanguage" promptText="Language" prefWidth="150"/>
                    <ComboBox fx:id="cbFilterLevel"    promptText="Level"    prefWidth="130"/>
                    <ComboBox fx:id="cbFilterStatus"   promptText="Status"   prefWidth="130"/>
                    <ComboBox fx:id="cbSortCourse"     promptText="Sort"     prefWidth="120"/>
                    <Button text="🔍" onAction="#applySearch" styleClass="btn-primary"/>
                </HBox>
            </VBox>

            <!-- ===== COURSES TABLE ===== -->
            <VBox spacing="0" styleClass="card" VBox.vgrow="ALWAYS">
                <HBox styleClass="card-header" alignment="CENTER_LEFT">
                    <Label text="All Courses" styleClass="card-header-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                </HBox>
                <VBox styleClass="card-body" spacing="0" VBox.vgrow="ALWAYS">
                    <TableView fx:id="tableCourses" prefHeight="-1" minHeight="120" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colId"          text="ID"             prefWidth="60"/>
                            <TableColumn fx:id="colTitle"       text="TITLE"          prefWidth="260"/>
                            <TableColumn fx:id="colLevel"       text="LEVEL"          prefWidth="120"/>
                            <TableColumn fx:id="colStatus"      text="STATUS"         prefWidth="110"/>
                            <TableColumn fx:id="colPublishedAt" text="PUBLISHED DATE" prefWidth="160"/>
                            <TableColumn fx:id="colAuthorId"    text="AUTHOR"         prefWidth="90"/>
                            <TableColumn fx:id="colLanguageId"  text="LANGUAGE"       prefWidth="100"/>
                        </columns>
                    </TableView>
                </VBox>
            </VBox>

            <!-- ===== FOOTER ===== -->
            <HBox>
                <Label text="© 2026 LinguaLearn. All rights reserved." styleClass="footer"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="LinguaLearn Admin v1.0" styleClass="footer"/>
            </HBox>

        </VBox>
    </content>
</ScrollPane>
