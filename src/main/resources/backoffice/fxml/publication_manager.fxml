<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.controllers.backoffice.PublicationBackofficeController"
      stylesheets="@../css/style.css"
      spacing="12" style="-fx-background-color: #f1f5f9; -fx-padding: 0 12 12 12;">

    <!-- HEADER -->
    <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 14 0 4 0;">
        <Label text="📰 Publications" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="statusLabel" text="" style="-fx-text-fill: #4f46e5; -fx-font-size: 12px; -fx-font-weight: bold;"/>
    </HBox>

    <!-- KPI CARDS -->
    <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 0 0 4 0;">
        <VBox alignment="CENTER" spacing="3" style="-fx-background-color: white; -fx-padding: 12 20; -fx-background-radius: 12; -fx-border-color: #dbeafe; -fx-border-radius: 12; -fx-effect: dropshadow(gaussian, rgba(37,99,235,0.08), 8, 0, 0, 2);">
            <Label text="📄 Publications" style="-fx-text-fill: #64748b; -fx-font-size: 11px;"/>
            <Label fx:id="kpiTotalPublicationsLabel" text="0" style="-fx-text-fill: #1d4ed8; -fx-font-size: 24px; -fx-font-weight: bold;"/>
        </VBox>
        <VBox alignment="CENTER" spacing="3" style="-fx-background-color: white; -fx-padding: 12 20; -fx-background-radius: 12; -fx-border-color: #dcfce7; -fx-border-radius: 12; -fx-effect: dropshadow(gaussian, rgba(21,128,61,0.08), 8, 0, 0, 2);">
            <Label text="👍 Likes" style="-fx-text-fill: #64748b; -fx-font-size: 11px;"/>
            <Label fx:id="kpiTotalLikesLabel" text="0" style="-fx-text-fill: #15803d; -fx-font-size: 24px; -fx-font-weight: bold;"/>
        </VBox>
        <VBox alignment="CENTER" spacing="3" style="-fx-background-color: white; -fx-padding: 12 20; -fx-background-radius: 12; -fx-border-color: #fee2e2; -fx-border-radius: 12; -fx-effect: dropshadow(gaussian, rgba(185,28,28,0.08), 8, 0, 0, 2);">
            <Label text="🚨 Signalements" style="-fx-text-fill: #64748b; -fx-font-size: 11px;"/>
            <Label fx:id="kpiTotalReportsLabel" text="0" style="-fx-text-fill: #b91c1c; -fx-font-size: 24px; -fx-font-weight: bold;"/>
        </VBox>
        <VBox alignment="CENTER" spacing="3" style="-fx-background-color: white; -fx-padding: 12 20; -fx-background-radius: 12; -fx-border-color: #ede9fe; -fx-border-radius: 12; -fx-effect: dropshadow(gaussian, rgba(109,40,217,0.08), 8, 0, 0, 2);">
            <Label text="🏷️ Types" style="-fx-text-fill: #64748b; -fx-font-size: 11px;"/>
            <Label fx:id="kpiTypesLabel" text="0" style="-fx-text-fill: #6d28d9; -fx-font-size: 24px; -fx-font-weight: bold;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="➕ Ajouter" onAction="#openAddPage"
                style="-fx-background-color: #16a34a; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 10 22; -fx-background-radius: 10; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(21,128,61,0.25), 6, 0, 0, 2);"/>
    </HBox>

    <!-- FILTER BAR -->
    <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: white; -fx-padding: 10 14; -fx-background-radius: 10; -fx-border-color: #e2e8f0; -fx-border-radius: 10;">
        <TextField fx:id="searchTitreField" promptText="🔍 Rechercher par titre..."
                   style="-fx-pref-width: 260; -fx-background-color: #f8fafc; -fx-border-color: #cbd5e1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8 12; -fx-font-size: 13px;"/>
        <ComboBox fx:id="filterTypeCombo" promptText="Type"
                  style="-fx-pref-width: 140; -fx-background-color: #f8fafc; -fx-border-color: #cbd5e1; -fx-border-radius: 8;"/>
        <TextField fx:id="minLikesField" promptText="Likes min"
                   style="-fx-pref-width: 110; -fx-background-color: #f8fafc; -fx-border-color: #cbd5e1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8 12; -fx-font-size: 13px;"/>
        <Button text="🔄 Rafraîchir" onAction="#refresh"
                style="-fx-background-color: #64748b; -fx-text-fill: white; -fx-font-size: 12px; -fx-padding: 8 14; -fx-background-radius: 8; -fx-cursor: hand;"/>
        <Button text="❌ Reset" onAction="#resetFilters"
                style="-fx-background-color: #334155; -fx-text-fill: white; -fx-font-size: 12px; -fx-padding: 8 14; -fx-background-radius: 8; -fx-cursor: hand;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="Cartes/page" style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
        <ComboBox fx:id="pageSizeComboBox" prefWidth="90"
                  style="-fx-background-color: #f8fafc; -fx-border-color: #cbd5e1; -fx-border-radius: 8; -fx-font-size: 12px;"/>
    </HBox>

    <!-- CARDS GRID -->
    <ScrollPane fx:id="cardsScrollPane" VBox.vgrow="ALWAYS" fitToWidth="true"
                style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;">
        <FlowPane fx:id="cardsPane" hgap="16" vgap="16"
                  style="-fx-padding: 8 4 8 4; -fx-background-color: transparent;"/>
    </ScrollPane>

    <!-- PAGINATION -->
    <HBox alignment="CENTER" spacing="10" style="-fx-padding: 4 0 0 0;">
        <Button fx:id="firstPageButton" text="⏮" onAction="#goToFirstPage"
                style="-fx-background-color: #e2e8f0; -fx-text-fill: #334155; -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand;"/>
        <Pagination fx:id="pagination" maxPageIndicatorCount="8"
                    style="-fx-page-information-visible: false;"/>
        <Button fx:id="lastPageButton" text="⏭" onAction="#goToLastPage"
                style="-fx-background-color: #e2e8f0; -fx-text-fill: #334155; -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand;"/>
        <Label fx:id="pageInfoLabel" text="0-0 / 0"
               style="-fx-text-fill: #64748b; -fx-font-size: 12px; -fx-font-weight: bold;"/>
    </HBox>

</VBox>
