<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.backoffice.CommentaireBackofficeController"
      stylesheets="@../css/style.css"
      spacing="12" style="-fx-background-color: #f8fafc; -fx-padding: 0 8 0 8;">

    <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 8 4 4 4;">
        <Button text="← Dashboard" onAction="#goToDashboard"
                style="-fx-background-color: #4f46e5; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 8 16; -fx-background-radius: 6; -fx-cursor: hand;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="💬 Commentaires Manager" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
    </HBox>

    <VBox alignment="CENTER" style="-fx-padding: 8 0 2 0;">
        <Label text="Commentaires"
               style="-fx-font-size: 34px; -fx-font-weight: bold; -fx-text-fill: #2563eb;"/>
    </VBox>

    <HBox alignment="CENTER" spacing="12" style="-fx-padding: 0 4 8 4;">
        <VBox alignment="CENTER" spacing="4" style="-fx-background-color: white; -fx-padding: 10 18; -fx-background-radius: 8; -fx-border-color: #dbeafe; -fx-border-radius: 8;">
            <Label text="Commentaires" style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
            <Label fx:id="kpiTotalCommentairesLabel" text="0" style="-fx-text-fill: #1d4ed8; -fx-font-size: 22px; -fx-font-weight: bold;"/>
        </VBox>
        <VBox alignment="CENTER" spacing="4" style="-fx-background-color: white; -fx-padding: 10 18; -fx-background-radius: 8; -fx-border-color: #dcfce7; -fx-border-radius: 8;">
            <Label text="Publications liées" style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
            <Label fx:id="kpiPublicationsLieesLabel" text="0" style="-fx-text-fill: #15803d; -fx-font-size: 22px; -fx-font-weight: bold;"/>
        </VBox>
        <VBox alignment="CENTER" spacing="4" style="-fx-background-color: white; -fx-padding: 10 18; -fx-background-radius: 8; -fx-border-color: #ede9fe; -fx-border-radius: 8;">
            <Label text="Longueur moyenne" style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
            <Label fx:id="kpiAvgLengthLabel" text="0" style="-fx-text-fill: #6d28d9; -fx-font-size: 22px; -fx-font-weight: bold;"/>
        </VBox>
    </HBox>

    <HBox alignment="CENTER" spacing="10" style="-fx-padding: 0 4 8 4;">
        <TextField fx:id="searchContenuField" promptText="🔍 Rechercher dans le contenu..."
                   style="-fx-pref-width: 360; -fx-background-color: white; -fx-border-color: #cbd5e1; -fx-border-radius: 6; -fx-padding: 8 12; -fx-font-size: 13px;"/>

        <TextField fx:id="filterPublicationIdField" promptText="Publication ID"
                   style="-fx-pref-width: 180; -fx-background-color: white; -fx-border-color: #cbd5e1; -fx-border-radius: 6; -fx-padding: 8 12; -fx-font-size: 13px;"/>

        <Button text="🔄 Rafraîchir" onAction="#refresh"
                style="-fx-background-color: #64748b; -fx-text-fill: white; -fx-font-size: 13px; -fx-padding: 8 16; -fx-background-radius: 6; -fx-cursor: hand;"/>

        <Button text="❌ Reset" onAction="#resetFilters"
                style="-fx-background-color: #334155; -fx-text-fill: white; -fx-font-size: 13px; -fx-padding: 8 16; -fx-background-radius: 6; -fx-cursor: hand;"/>
    </HBox>

    <VBox VBox.vgrow="ALWAYS" style="-fx-padding: 0 4 0 4;" spacing="0">
        <TableView fx:id="commentaireTable" VBox.vgrow="ALWAYS"
                   style="-fx-background-color: white; -fx-border-color: #cbd5e1; -fx-border-width: 1; -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 13px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 6, 0, 0, 2);">
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="80" maxWidth="90"/>
                <TableColumn fx:id="colContenu" text="Contenu" prefWidth="520"/>
                <TableColumn fx:id="colPublicationId" text="Publication ID" prefWidth="160"/>
            </columns>
        </TableView>

        <HBox alignment="CENTER_RIGHT" spacing="10" style="-fx-padding: 10 0 0 0;">
            <Button fx:id="firstPageButton" text="⏮" onAction="#goToFirstPage"
                    style="-fx-background-color: #e2e8f0; -fx-text-fill: #334155; -fx-font-size: 12px; -fx-background-radius: 6; -fx-cursor: hand;"/>
            <Label text="Lignes/page" style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
            <ComboBox fx:id="pageSizeComboBox" prefWidth="90"
                      style="-fx-background-color: white; -fx-border-color: #cbd5e1; -fx-border-radius: 6; -fx-font-size: 12px;"/>
            <Pagination fx:id="pagination" maxPageIndicatorCount="8"
                        style="-fx-page-information-visible: false;"/>
            <Button fx:id="lastPageButton" text="⏭" onAction="#goToLastPage"
                    style="-fx-background-color: #e2e8f0; -fx-text-fill: #334155; -fx-font-size: 12px; -fx-background-radius: 6; -fx-cursor: hand;"/>
            <Label fx:id="pageInfoLabel" text="0-0 / 0"
                   style="-fx-text-fill: #64748b; -fx-font-size: 12px; -fx-font-weight: bold;"/>
        </HBox>
    </VBox>

    <VBox spacing="10" style="-fx-padding: 10 4 0 4;">
        <HBox alignment="CENTER" spacing="10" style="-fx-padding: 6 0 6 0;">
            <Button text="➕ Ajouter" onAction="#openAddPage"
                    style="-fx-background-color: #16a34a; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 10 24; -fx-background-radius: 8; -fx-cursor: hand;"/>
            <Button text="👁️ Voir" onAction="#openShowPage"
                    style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 10 24; -fx-background-radius: 8; -fx-cursor: hand;"/>
            <Button text="✏️ Modifier" onAction="#openEditPage"
                    style="-fx-background-color: #f59e0b; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 10 24; -fx-background-radius: 8; -fx-cursor: hand;"/>
            <Button text="🗑️ Supprimer" onAction="#deleteCommentaire"
                    style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 10 24; -fx-background-radius: 8; -fx-cursor: hand;"/>
            <Button text="🧹 Désélectionner" onAction="#clearSelection"
                    style="-fx-background-color: #475569; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 10 24; -fx-background-radius: 8; -fx-cursor: hand;"/>
        </HBox>

        <Label fx:id="statusLabel" text="" style="-fx-text-fill: #4f46e5; -fx-font-size: 12px; -fx-font-weight: bold;"/>
    </VBox>

</VBox>
