<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" styleClass="main-container"
      stylesheets="@../css/style.css"
      xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/25"
      fx:controller="controllers.frontoffice.PublicationController">

    <padding><Insets top="20" left="0" right="0" bottom="20"/></padding>

    <!-- BARRE DE RECHERCHE + TRI + BOUTON AJOUTER CENTRÉS -->
    <HBox alignment="CENTER" spacing="10">
        <HBox alignment="CENTER_LEFT" spacing="10"
              styleClass="search-bar-container"
              prefWidth="500">
            <Label styleClass="search-icon" text="🔍"/>
            <TextField fx:id="searchField"
                       onKeyReleased="#handleSearch"
                       promptText="Rechercher une publication..."
                       styleClass="search-field"
                       HBox.hgrow="ALWAYS"/>
        </HBox>

        <!-- BOUTON TRI -->
        <VBox alignment="CENTER" onMouseClicked="#handleTri"
              prefHeight="45" prefWidth="45"
              styleClass="add-card">
            <Label fx:id="triIcon" text="↑↓"/>
        </VBox>

        <!-- BOUTON AJOUTER -->
        <VBox alignment="CENTER" onMouseClicked="#handleAjouter"
              prefHeight="45" prefWidth="45"
              styleClass="add-card">
            <Label styleClass="add-icon" text="+"/>
        </VBox>
    </HBox>

    <!-- STORIES -->
    <HBox alignment="CENTER">
        <ScrollPane fitToHeight="false"
                    hbarPolicy="AS_NEEDED"
                    vbarPolicy="NEVER"
                    prefHeight="170"
                    prefWidth="600"
                    minHeight="170"
                    styleClass="scroll-pane">
            <HBox fx:id="storiesContainer" spacing="15"
                  alignment="CENTER_LEFT"
                  minHeight="150"
                  prefHeight="150">
                <padding><Insets left="10" right="10" top="15" bottom="15"/></padding>
            </HBox>
        </ScrollPane>
    </HBox>


    <!-- LISTE DES PUBLICATIONS CENTRÉE -->
    <ScrollPane fitToWidth="true" styleClass="scroll-pane" VBox.vgrow="ALWAYS">
        <HBox alignment="CENTER">
            <VBox fx:id="publicationsContainer" spacing="15"
                  alignment="CENTER" prefWidth="600" maxWidth="600">
                <padding><Insets top="10" bottom="10"/></padding>
            </VBox>
        </HBox>
    </ScrollPane>



</VBox>