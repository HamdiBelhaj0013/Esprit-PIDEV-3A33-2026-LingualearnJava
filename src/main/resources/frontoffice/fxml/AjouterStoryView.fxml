<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>

<VBox spacing="12" styleClass="main-container"
      stylesheets="@../css/style.css"
      prefWidth="400"
      xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/25"
      fx:controller="org.example.controllers.frontoffice.AjouterStoryController">

    <padding><Insets top="30" left="40" right="40" bottom="30"/></padding>

    <Label text="Ajouter une story" styleClass="view-title"/>

    <Label text="Titre *"/>
    <TextField fx:id="titreField" promptText="Titre de la story"/>
    <Label fx:id="titreError" text="" styleClass="error-label"/>

    <Label text="Contenu *"/>
    <TextArea fx:id="contenuArea" promptText="Contenu de la story..."
              prefHeight="80" wrapText="true"/>
    <Label fx:id="contenuError" text="" styleClass="error-label"/>

    <Label text="Image"/>
    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="imagePathField" promptText="Aucune image..."
                   editable="false" HBox.hgrow="ALWAYS"/>
        <Button text="📁 Choisir" styleClass="btn-secondary" onAction="#handleChoisirImage"/>
    </HBox>

    <ImageView fx:id="imagePreview" fitWidth="150" fitHeight="100"
               preserveRatio="true" visible="false"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Annuler" styleClass="btn-secondary" onAction="#handleAnnuler"/>
        <Button text="Publier" styleClass="btn-primary" onAction="#handlePublier"/>
    </HBox>

</VBox>