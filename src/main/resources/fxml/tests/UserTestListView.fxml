<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.controller.tests.UserTestListController"
      styleClass="dashboard-root"
      stylesheets="@../../css/style.css"
      spacing="0">

    <!-- ── Header ─────────────────────────────────────────────── -->
    <HBox styleClass="dashboard-header" alignment="CENTER_LEFT" spacing="16">
        <Label text="LinguaLearn" styleClass="header-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="userNameLabel" text="" styleClass="role-badge-user"/>
    </HBox>

    <VBox VBox.vgrow="ALWAYS" spacing="0">
        <padding><Insets top="28" right="32" bottom="28" left="32"/></padding>

        <!-- ── Titre + retour ───────────────────────────────────── -->
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-padding: 0 0 20 0;">
            <Button text="← Retour" onAction="#handleBack"
                    style="-fx-background-color: transparent; -fx-text-fill: #3b5bdb;
                           -fx-font-size: 13px; -fx-cursor: hand;
                           -fx-border-color: #3b5bdb; -fx-border-radius: 6;
                           -fx-background-radius: 6; -fx-padding: 6 14;"/>
            <VBox spacing="2">
                <Label text="🌍 Tests de Certification Internationaux"
                       style="-fx-font-size: 22px; -fx-font-weight: bold;
                              -fx-text-fill: #1a237e;"/>
                <Label fx:id="totalTestsLabel" text="0 test(s) disponible(s)"
                       style="-fx-font-size: 13px; -fx-text-fill: #757575;"/>
            </VBox>
        </HBox>

        <!-- ── Filtres ───────────────────────────────────────────── -->
        <HBox spacing="12" alignment="CENTER_LEFT"
              style="-fx-padding: 12 16; -fx-background-color: white;
                     -fx-background-radius: 8; -fx-border-color: #e3e8f0;
                     -fx-border-radius: 8; -fx-border-width: 1;
                     -fx-margin: 0 0 16 0;">
            <TextField fx:id="searchField"
                       promptText="🔍 Rechercher un test..."
                       prefWidth="240"
                       style="-fx-pref-height: 36px; -fx-background-radius: 6;
                              -fx-border-radius: 6; -fx-border-color: #d1d5db;
                              -fx-border-width: 1; -fx-font-size: 13px;
                              -fx-padding: 6 10;"/>
            <ComboBox fx:id="typeFilterCombo"  prefWidth="140"
                      style="-fx-pref-height: 36px; -fx-font-size: 13px;"/>
            <ComboBox fx:id="levelFilterCombo" prefWidth="120"
                      style="-fx-pref-height: 36px; -fx-font-size: 13px;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="👁 Voir le test sélectionné"
                    onAction="#handleViewTest"
                    style="-fx-background-color: #3b5bdb; -fx-text-fill: white;
                           -fx-font-size: 13px; -fx-font-weight: bold;
                           -fx-background-radius: 6; -fx-cursor: hand;
                           -fx-padding: 8 18;"/>
        </HBox>

        <!-- ── TableView ─────────────────────────────────────────── -->
        <VBox VBox.vgrow="ALWAYS"
              style="-fx-background-color: white; -fx-background-radius: 10;
                     -fx-border-color: #e3e8f0; -fx-border-radius: 10;
                     -fx-border-width: 1; -fx-margin: 16 0 0 0;">
            <TableView fx:id="testsTable" VBox.vgrow="ALWAYS"
                       style="-fx-background-color: white; -fx-border-color: transparent;
                              -fx-table-cell-border-color: #f0f4f8;">
                <columns>
                    <TableColumn fx:id="colType"        text="TYPE"        prefWidth="100"/>
                    <TableColumn fx:id="colTitle"       text="TITRE"       prefWidth="240"/>
                    <TableColumn fx:id="colLanguage"    text="LANGUE"      prefWidth="100"/>
                    <TableColumn fx:id="colLevel"       text="NIVEAU"      prefWidth="80"/>
                    <TableColumn fx:id="colDuration"    text="DURÉE"       prefWidth="80"/>
                    <TableColumn fx:id="colNbQuestions" text="QUESTIONS"   prefWidth="90"/>
                    <TableColumn fx:id="colLastScore"   text="📊 MA NOTE"   prefWidth="100"/>
                    <TableColumn fx:id="colAverageScore" text="📈 MOYENNE"  prefWidth="100"/>
                </columns>
                <placeholder>
                    <Label text="Aucun test disponible pour le moment."
                           style="-fx-font-size: 14px; -fx-text-fill: #6c7a99;"/>
                </placeholder>
            </TableView>
        </VBox>

        <Label text="💡 Double-cliquez sur un test pour voir ses questions."
               style="-fx-font-size: 12px; -fx-text-fill: #6c7a99;
                      -fx-padding: 8 0 0 0;"/>
    </VBox>

</VBox>