<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!--
  UserDashboard.fxml  — redesigned colorful UI
  Place at: src/main/resources/fxml/UserDashboard.fxml
  Controller: org.example.controller.UserDashboardController
  Note: fx:id="headerUserLabel" is new — add to UserDashboardController:
        @FXML private Label headerUserLabel;
        and in the init method add: headerUserLabel.setText(user.getFirstName());
-->
<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.controller.UserDashboardController"
      stylesheets="@../css/style.css"
      spacing="0"
      style="-fx-background-color:#eef2ff; -fx-font-family:'Segoe UI',Arial,sans-serif;">

    <!-- ══ HEADER ══════════════════════════════════════════════════════════ -->
    <HBox alignment="CENTER_LEFT" spacing="12"
          style="-fx-background-color:linear-gradient(to right,#1a237e,#283593);
                 -fx-padding:0 28; -fx-pref-height:62; -fx-min-height:62;
                 -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.28),8,0,0,3);">

        <!-- Brand pill -->
        <Label text="L"
               style="-fx-font-size:18px;-fx-font-weight:bold;-fx-text-fill:#ffd600;
                      -fx-background-color:rgba(255,214,0,0.18);-fx-background-radius:8;
                      -fx-padding:4 11;"/>
        <Label text="LinguaLearn"
               style="-fx-font-size:19px;-fx-font-weight:bold;-fx-text-fill:white;"/>

        <Region HBox.hgrow="ALWAYS"/>

        <!-- Right side -->
        <HBox spacing="12" alignment="CENTER">
            <Label fx:id="headerUserLabel" text=""
                   style="-fx-text-fill:rgba(255,255,255,0.88);-fx-font-size:13px;
                          -fx-font-weight:bold;"/>
            <Label text="USER"
                   style="-fx-background-color:rgba(255,255,255,0.18);-fx-text-fill:white;
                          -fx-font-size:10px;-fx-font-weight:bold;-fx-background-radius:20;
                          -fx-padding:3 10;"/>
            <Button text="Déconnexion" onAction="#handleLogout"
                    style="-fx-background-color:rgba(255,255,255,0.12);-fx-text-fill:white;
                           -fx-font-size:12px;-fx-cursor:hand;-fx-background-radius:8;
                           -fx-border-color:rgba(255,255,255,0.38);-fx-border-radius:8;
                           -fx-border-width:1;-fx-padding:6 16;"/>
        </HBox>
    </HBox>

    <!-- ══ HERO BANNER ══════════════════════════════════════════════════════ -->
    <HBox alignment="CENTER_LEFT"
          style="-fx-background-color:linear-gradient(to right,#1565c0,#0288d1,#00838f);
                 -fx-padding:30 48;">
        <VBox spacing="8" HBox.hgrow="ALWAYS">
            <Label fx:id="welcomeLabel" text="Bienvenue !"
                   style="-fx-font-size:28px;-fx-font-weight:bold;-fx-text-fill:white;"/>
            <Label fx:id="userInfoLabel" text=""
                   style="-fx-font-size:13px;-fx-text-fill:rgba(255,255,255,0.80);"
                   wrapText="true"/>
            <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding:6 0 0 0;">
                <Label fx:id="planLabel" text="Plan FREE"
                       style="-fx-background-color:rgba(255,255,255,0.22);-fx-text-fill:white;
                              -fx-font-size:11px;-fx-font-weight:bold;-fx-background-radius:20;
                              -fx-padding:4 14;"/>
                <Label text="✨ Passez à Premium pour accéder à plus de certifications"
                       style="-fx-text-fill:rgba(255,255,255,0.60);-fx-font-size:11px;"/>
            </HBox>
        </VBox>

        <!-- Right decorative icons -->
        <HBox spacing="28" alignment="CENTER">
            <VBox alignment="CENTER" spacing="4">
                <Label text="📚" style="-fx-font-size:30px;"/>
                <Label text="Tests" style="-fx-text-fill:rgba(255,255,255,0.72);-fx-font-size:10px;"/>
            </VBox>
            <VBox alignment="CENTER" spacing="4">
                <Label text="🏆" style="-fx-font-size:30px;"/>
                <Label text="Scores" style="-fx-text-fill:rgba(255,255,255,0.72);-fx-font-size:10px;"/>
            </VBox>
            <VBox alignment="CENTER" spacing="4">
                <Label text="🌍" style="-fx-font-size:30px;"/>
                <Label text="Certifications" style="-fx-text-fill:rgba(255,255,255,0.72);-fx-font-size:10px;"/>
            </VBox>
        </HBox>
    </HBox>

    <!-- ══ MAIN CONTENT ═════════════════════════════════════════════════════ -->
    <VBox VBox.vgrow="ALWAYS" spacing="0" style="-fx-background-color:#eef2ff;">
        <padding><Insets top="36" right="52" bottom="36" left="52"/></padding>

        <!-- Section label -->
        <HBox alignment="CENTER_LEFT" spacing="0" style="-fx-padding:0 0 22 0;">
            <Label text="Accès rapide"
                   style="-fx-font-size:17px;-fx-font-weight:bold;-fx-text-fill:#1a237e;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="Que souhaitez-vous faire aujourd'hui ?"
                   style="-fx-font-size:12px;-fx-text-fill:#6c7a99;"/>
        </HBox>

        <!-- ── Cards ─────────────────────────────────────────────────────── -->
        <HBox spacing="24">

            <!-- ─── Card: Tests de Certification ─────────────────────────── -->
            <VBox spacing="0" HBox.hgrow="ALWAYS"
                  style="-fx-background-color:white;-fx-background-radius:18;
                         -fx-effect:dropshadow(gaussian,rgba(21,101,192,0.15),20,0,0,6);">

                <!-- top accent bar -->
                <HBox style="-fx-background-color:linear-gradient(to right,#1565c0,#0288d1);
                             -fx-background-radius:18 18 0 0;-fx-pref-height:6;-fx-min-height:6;"/>

                <VBox spacing="16" alignment="CENTER" style="-fx-padding:32 28 30 28;">

                    <!-- Icon in colored circle -->
                    <StackPane style="-fx-background-color:#e3f2fd;-fx-background-radius:50;
                                      -fx-min-width:72;-fx-min-height:72;
                                      -fx-max-width:72;-fx-max-height:72;">
                        <Label text="🌍" style="-fx-font-size:34px;"/>
                    </StackPane>

                    <VBox spacing="5" alignment="CENTER">
                        <Label text="Tests de Certification"
                               style="-fx-font-size:16px;-fx-font-weight:bold;-fx-text-fill:#1a237e;"
                               wrapText="true" textAlignment="CENTER" alignment="CENTER"/>
                        <Label text="TOEFL · IELTS · DELF · DALF · TCF · Cambridge"
                               style="-fx-text-fill:#6c7a99;-fx-font-size:11px;"
                               wrapText="true" alignment="CENTER" textAlignment="CENTER"/>
                    </VBox>

                    <!-- Feature list -->
                    <VBox spacing="7" style="-fx-padding:2 0 0 0;">
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label text="✓"
                                   style="-fx-text-fill:#1565c0;-fx-font-weight:bold;-fx-font-size:13px;"/>
                            <Label text="Questions mélangées aléatoirement"
                                   style="-fx-font-size:12px;-fx-text-fill:#374151;"/>
                        </HBox>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label text="✓"
                                   style="-fx-text-fill:#1565c0;-fx-font-weight:bold;-fx-font-size:13px;"/>
                            <Label text="Score affiché sur 20 pts"
                                   style="-fx-font-size:12px;-fx-text-fill:#374151;"/>
                        </HBox>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label text="✓"
                                   style="-fx-text-fill:#1565c0;-fx-font-weight:bold;-fx-font-size:13px;"/>
                            <Label text="Chronomètre et pénalités automatiques"
                                   style="-fx-font-size:12px;-fx-text-fill:#374151;"/>
                        </HBox>
                    </VBox>

                    <Button text="🚀  Voir les tests disponibles"
                            onAction="#handleOpenTests" maxWidth="Infinity"
                            style="-fx-background-color:linear-gradient(to right,#1565c0,#0288d1);
                                   -fx-text-fill:white;-fx-font-size:13px;-fx-font-weight:bold;
                                   -fx-background-radius:10;-fx-cursor:hand;-fx-padding:12 20;
                                   -fx-effect:dropshadow(gaussian,rgba(21,101,192,0.35),8,0,0,3);"/>
                </VBox>
            </VBox>

            <!-- ─── Card: Mon Profil ──────────────────────────────────────── -->
            <VBox spacing="0" HBox.hgrow="ALWAYS"
                  style="-fx-background-color:white;-fx-background-radius:18;
                         -fx-effect:dropshadow(gaussian,rgba(0,131,143,0.15),20,0,0,6);">

                <HBox style="-fx-background-color:linear-gradient(to right,#00897b,#00acc1);
                             -fx-background-radius:18 18 0 0;-fx-pref-height:6;-fx-min-height:6;"/>

                <VBox spacing="16" alignment="CENTER" style="-fx-padding:32 28 30 28;">

                    <StackPane style="-fx-background-color:#e0f2f1;-fx-background-radius:50;
                                      -fx-min-width:72;-fx-min-height:72;
                                      -fx-max-width:72;-fx-max-height:72;">
                        <Label text="👤" style="-fx-font-size:34px;"/>
                    </StackPane>

                    <VBox spacing="5" alignment="CENTER">
                        <Label text="Mon Profil"
                               style="-fx-font-size:16px;-fx-font-weight:bold;-fx-text-fill:#1a237e;"/>
                        <Label fx:id="planLabelCard" text="Plan FREE"
                               style="-fx-background-color:#e0f7fa;-fx-text-fill:#00796b;
                                      -fx-font-size:11px;-fx-font-weight:bold;
                                      -fx-background-radius:20;-fx-padding:3 12;"/>
                    </VBox>

                    <VBox spacing="7" style="-fx-padding:2 0 0 0;">
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label text="✓"
                                   style="-fx-text-fill:#00897b;-fx-font-weight:bold;-fx-font-size:13px;"/>
                            <Label text="Statistiques d'apprentissage"
                                   style="-fx-font-size:12px;-fx-text-fill:#374151;"/>
                        </HBox>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label text="✓"
                                   style="-fx-text-fill:#00897b;-fx-font-weight:bold;-fx-font-size:13px;"/>
                            <Label text="Historique de vos résultats"
                                   style="-fx-font-size:12px;-fx-text-fill:#374151;"/>
                        </HBox>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label text="✓"
                                   style="-fx-text-fill:#00897b;-fx-font-weight:bold;-fx-font-size:13px;"/>
                            <Label text="Recommandations personnalisées"
                                   style="-fx-font-size:12px;-fx-text-fill:#374151;"/>
                        </HBox>
                    </VBox>

                    <Button text="👤  Voir mon profil"
                            onAction="#handleOpenProfile" maxWidth="Infinity"
                            style="-fx-background-color:linear-gradient(to right,#00897b,#00acc1);
                                   -fx-text-fill:white;-fx-font-size:13px;-fx-font-weight:bold;
                                   -fx-background-radius:10;-fx-cursor:hand;-fx-padding:12 20;
                                   -fx-effect:dropshadow(gaussian,rgba(0,131,143,0.35),8,0,0,3);"/>
                </VBox>
            </VBox>

        </HBox>

        <!-- Tip -->
        <Label text="💡  Choisissez une certification, sélectionnez votre niveau, et passez votre test !"
               style="-fx-font-size:12px;-fx-text-fill:#9ca3af;-fx-padding:20 0 0 0;"
               wrapText="true"/>
    </VBox>

</VBox>
