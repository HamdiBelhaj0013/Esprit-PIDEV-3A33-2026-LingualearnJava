<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="org.example.controller.QuizPlayController"
           style="-fx-background-color: #f8fafc;" stylesheets="@styles.css"
           prefWidth="1200" prefHeight="800">

    <VBox alignment="TOP_CENTER" spacing="20" style="-fx-padding: 40;">
        
        <!-- Top Navigation -->
        <HBox alignment="CENTER_LEFT" maxWidth="800">
            <Button onAction="#goBack" styleClass="btn-outline" style="-fx-border-color: transparent; -fx-padding: 10;">
                <graphic>
                    <HBox spacing="8" alignment="CENTER">
                        <FontIcon iconLiteral="fas-arrow-left" iconSize="16" iconColor="#64748b"/>
                        <Label text="Back to Quiz Details" style="-fx-text-fill: #64748b; -fx-font-weight: bold;"/>
                    </HBox>
                </graphic>
            </Button>
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="quizTitleLabel" text="Quiz" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
        </HBox>

        <!-- Main Content -->
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-padding: 0;" maxWidth="800" VBox.vgrow="ALWAYS">
            <content>
                <VBox fx:id="exercicesContainer" spacing="20" style="-fx-padding: 10 0;">
                    <!-- Exercices will be loaded here dynamically -->
                </VBox>
            </content>
        </ScrollPane>

        <HBox alignment="CENTER_RIGHT" maxWidth="800">
            <Button text="Submit Answers" onAction="#submitAnswers" styleClass="btn-primary" style="-fx-padding: 10 20; -fx-font-size: 14px; -fx-font-weight: bold;"/>
        </HBox>

    </VBox>
</StackPane>
