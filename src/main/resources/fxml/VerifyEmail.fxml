<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="520.0" prefWidth="600.0"
           styleClass="root-pane"
           stylesheets="@../css/style.css"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="org.example.controller.VerifyEmailController">

    <VBox alignment="TOP_CENTER" maxWidth="652.0" prefHeight="520.0" prefWidth="652.0"
          spacing="18.0" styleClass="login-card">
        <padding>
            <Insets bottom="44.0" left="44.0" right="44.0" top="44.0"/>
        </padding>

        <!-- ── Brand ───────────────────────────── -->
        <Label styleClass="app-title" text="LinguaLearn"/>
        <Label styleClass="subtitle" text="Verify your email"/>

        <!-- ── Subtitle (updated with email address) ── -->
        <Label fx:id="subtitleLabel"
               styleClass="subtitle"
               text="We sent a 6-digit code to your email"
               wrapText="true"/>

        <!-- ── Code input ──────────────────────── -->
        <VBox spacing="4.0">
            <Label styleClass="field-label" text="Verification Code"/>
            <TextField fx:id="codeField"
                       promptText="Enter 6-digit code"
                       styleClass="input-field"
                       maxWidth="200.0"
                       alignment="CENTER"/>
            <Label fx:id="codeError"
                   managed="false" visible="false"
                   styleClass="error-label"
                   wrapText="true"/>
        </VBox>

        <!-- ── Success message ─────────────────── -->
        <Label fx:id="successLabel"
               managed="false" visible="false"
               styleClass="success-label"
               wrapText="true"/>

        <!-- ── Verify button ───────────────────── -->
        <Button text="Verify Email"
                onAction="#handleVerify"
                styleClass="login-btn"
                maxWidth="Infinity"
                defaultButton="true">
            <VBox.margin>
                <Insets top="6.0"/>
            </VBox.margin>
        </Button>

        <!-- ── Resend button ───────────────────── -->
        <Button fx:id="resendBtn"
                text="Resend code"
                onAction="#handleResend"
                styleClass="link-btn"
                maxWidth="Infinity"/>

        <!-- ── Back to login ───────────────────── -->
        <Button text="Back to Login"
                onAction="#handleBackToLogin"
                styleClass="link-btn"
                maxWidth="Infinity"/>

    </VBox>
</StackPane>
