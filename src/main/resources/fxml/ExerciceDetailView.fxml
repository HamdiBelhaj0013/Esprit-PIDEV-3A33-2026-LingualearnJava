<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="org.example.controller.ExerciceDetailController"
           stylesheets="@styles.css"
           prefWidth="1200"
           prefHeight="800"
           styleClass="detail-root">

    <VBox alignment="TOP_CENTER"
          spacing="24"
          style="-fx-padding: 35 45;">

        <!-- TOP NAVIGATION -->
        <HBox alignment="CENTER_LEFT" maxWidth="950">
            <Button onAction="#goBack"
                    styleClass="btn-outline"
                    style="-fx-border-color: transparent; -fx-background-color: transparent; -fx-padding: 10;">
                <graphic>
                    <HBox spacing="8" alignment="CENTER">
                        <FontIcon iconLiteral="fas-arrow-left"
                                  iconSize="15"
                                  iconColor="#64748b"/>
                        <Label text="Back to Catalog"
                               style="-fx-text-fill: #64748b; -fx-font-weight: bold;"/>
                    </HBox>
                </graphic>
            </Button>
        </HBox>

        <!-- MAIN CARD -->
        <VBox maxWidth="950"
              spacing="0"
              styleClass="detail-card">

            <!-- HEADER -->
            <VBox spacing="18" styleClass="detail-header">
                <HBox spacing="18" alignment="CENTER_LEFT">

                    <StackPane styleClass="detail-icon-box">
                        <FontIcon iconLiteral="fas-pen-fancy"
                                  iconSize="26"
                                  iconColor="white"/>
                    </StackPane>

                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label fx:id="typeLabel"
                               text="Multiple Choice"
                               styleClass="detail-type"/>

                        <Label fx:id="questionLabel"
                               text="Question goes here"
                               wrapText="true"
                               styleClass="detail-question"/>
                    </VBox>

                </HBox>
            </VBox>

            <!-- CONTENT AREA -->
            <VBox spacing="26" styleClass="detail-content">

                <!-- SUMMARY PANEL -->
                <VBox spacing="24" styleClass="summary-panel">

                    <!-- TITLE + QUIZ INFO -->
                    <HBox alignment="CENTER_LEFT" spacing="16">

                        <StackPane styleClass="summary-icon">
                            <FontIcon iconLiteral="fas-lightbulb"
                                      iconSize="20"
                                      iconColor="white"/>
                        </StackPane>

                        <VBox spacing="6" HBox.hgrow="ALWAYS">

                            <Label text="Exercise Overview"
                                   styleClass="summary-title"/>

                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <FontIcon iconLiteral="fas-book"
                                          iconSize="13"
                                          iconColor="#2563eb"/>

                                <Label text="Linked Quiz:"
                                       styleClass="inline-label"/>

                                <Label fx:id="quizLabel"
                                       text="No Linked Quiz"
                                       styleClass="inline-value"/>
                            </HBox>

                        </VBox>

                    </HBox>

                    <!-- CORRECT ANSWER ONLY -->
                    <VBox spacing="14"
                          styleClass="answer-focus-card">

                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <StackPane styleClass="small-icon-green">
                                <FontIcon iconLiteral="fas-check"
                                          iconSize="12"
                                          iconColor="white"/>
                            </StackPane>

                            <Label text="CORRECT ANSWER"
                                   styleClass="green-label"/>
                        </HBox>

                        <Label fx:id="answerLabel"
                               text="Correct answer"
                               wrapText="true"
                               styleClass="answer-focus-text"/>

                    </VBox>

                </VBox>

                <!-- META INFORMATION -->
                <HBox spacing="18">

                    <!-- DIFFICULTY -->
                    <VBox spacing="10"
                          HBox.hgrow="ALWAYS"
                          styleClass="meta-item">

                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <FontIcon iconLiteral="fas-signal"
                                      iconSize="13"
                                      iconColor="#64748b"/>

                            <Label text="Difficulty Level"
                                   styleClass="meta-label"/>
                        </HBox>

                        <HBox fx:id="diffContainer"
                              spacing="4"
                              alignment="CENTER_LEFT"/>
                    </VBox>

                    <!-- STATUS -->
                    <VBox spacing="10"
                          HBox.hgrow="ALWAYS"
                          styleClass="meta-item">

                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <FontIcon iconLiteral="fas-circle"
                                      iconSize="10"
                                      iconColor="#22c55e"/>

                            <Label text="Status"
                                   styleClass="meta-label"/>
                        </HBox>

                        <Label fx:id="statusLabel"
                               text="Active"
                               styleClass="badge-active"/>
                    </VBox>

                    <!-- GENERATION -->
                    <VBox spacing="10"
                          HBox.hgrow="ALWAYS"
                          styleClass="meta-item">

                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <FontIcon iconLiteral="fas-user-edit"
                                      iconSize="13"
                                      iconColor="#64748b"/>

                            <Label text="Generation"
                                   styleClass="meta-label"/>
                        </HBox>

                        <Label fx:id="aiLabel"
                               text="Human Created"
                               styleClass="meta-value"/>
                    </VBox>

                </HBox>

                <!-- FEEDBACK -->
                <VBox spacing="20"
                      styleClass="feedback-panel">

                    <HBox alignment="CENTER_LEFT">

                        <VBox spacing="5">
                            <Label text="How useful was this exercise?"
                                   styleClass="feedback-title"/>

                            <Label text="Your rating helps improve the learning experience"
                                   styleClass="feedback-subtitle"/>
                        </VBox>

                        <Region HBox.hgrow="ALWAYS"/>

                        <VBox alignment="CENTER_RIGHT" spacing="4">
                            <Label text="AVERAGE SCORE"
                                   styleClass="muted-label"/>

                            <HBox spacing="7" alignment="CENTER_RIGHT">
                                <FontIcon iconLiteral="fas-star"
                                          iconSize="18"
                                          iconColor="#f59e0b"/>

                                <Label fx:id="avgRatingLabel"
                                       text="0.0"
                                       styleClass="avg-rating"/>
                            </HBox>
                        </VBox>

                    </HBox>

                    <VBox alignment="CENTER"
                          spacing="10"
                          styleClass="rating-box">

                        <HBox fx:id="ratingStarContainer"
                              spacing="16"
                              alignment="CENTER"/>

                        <Label fx:id="userRatingFeedback"
                               text="Click to rate"
                               alignment="CENTER"
                               maxWidth="Infinity"
                               styleClass="rating-feedback"/>
                    </VBox>

                </VBox>

            </VBox>

        </VBox>

    </VBox>

</StackPane>