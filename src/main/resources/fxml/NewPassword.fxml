<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="520.0" prefWidth="600.0" styleClass="root-pane"
           stylesheets="@../css/style.css"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="org.example.controller.NewPasswordController">

    <VBox alignment="TOP_CENTER" maxWidth="652.0" prefHeight="520.0" prefWidth="652.0"
          spacing="18.0" styleClass="login-card">

        <padding>
            <Insets bottom="44.0" left="44.0" right="44.0" top="44.0" />
        </padding>

        <!-- ── Title ───────────────────────────────── -->
        <Label styleClass="app-title" text="Set New Password" />
        <Label styleClass="subtitle" text="Choose a strong password" />

        <!-- ── New password ─────────────────────────── -->
        <VBox spacing="4.0">
            <Label styleClass="field-label" text="New Password" />
            <PasswordField fx:id="passwordField" promptText="New password (min. 6 chars)"
                           styleClass="input-field" />
            <Label fx:id="passwordError" managed="false" styleClass="error-label" visible="false" />
        </VBox>

        <!-- ── Confirm password ─────────────────────── -->
        <VBox spacing="4.0">
            <Label styleClass="field-label" text="Confirm Password" />
            <PasswordField fx:id="confirmField" promptText="Confirm new password"
                           styleClass="input-field" />
            <Label fx:id="confirmError" managed="false" styleClass="error-label" visible="false" />
        </VBox>

        <!-- ── General error ────────────────────────── -->
        <Label fx:id="errorLabel" managed="false" maxWidth="400.0"
               styleClass="error-label" visible="false" wrapText="true" />

        <!-- ── Reset button ─────────────────────────── -->
        <Button defaultButton="true" maxWidth="Infinity"
                onAction="#handleReset" styleClass="login-btn" text="Reset Password">
            <VBox.margin>
                <Insets top="6.0" />
            </VBox.margin>
        </Button>

    </VBox>
</StackPane>
