<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.controller.admin.UserListController"
      spacing="16.0">

    <!-- Page header -->
    <HBox alignment="CENTER_LEFT" spacing="12.0">
        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
            <Label text="User Management" styleClass="page-title"/>
            <Label text="Search, filter, and manage all users" styleClass="page-subtitle"/>
        </VBox>
        <Button text="+ Create User" styleClass="btn-primary" onAction="#handleCreate"/>
        <Button text="Refresh"       styleClass="btn-outline" onAction="#handleRefresh"/>
        <Button text="Export CSV"    styleClass="btn-outline-muted" disable="true"/>
    </HBox>

    <!-- Filter bar -->
    <HBox spacing="10.0" alignment="CENTER_LEFT" styleClass="table-card">
        <padding>
            <Insets top="12.0" right="14.0" bottom="12.0" left="14.0"/>
        </padding>
        <TextField  fx:id="searchField"  promptText="Search name or email…"
                    styleClass="search-field"/>
        <ComboBox   fx:id="statusFilter" promptText="Status"
                    styleClass="filter-combo" prefWidth="130.0"/>
        <ComboBox   fx:id="roleFilter"   promptText="Role"
                    styleClass="filter-combo" prefWidth="160.0"/>
        <ComboBox   fx:id="planFilter"   promptText="Plan"
                    styleClass="filter-combo" prefWidth="120.0"/>
        <ComboBox   fx:id="sortCombo"    promptText="Sort by"
                    styleClass="filter-combo" prefWidth="150.0"/>
        <Button text="Apply" styleClass="btn-primary,btn-sm" onAction="#handleApplyFilters"/>
        <Button text="Clear" styleClass="btn-outline,btn-sm"  onAction="#handleClearFilters"/>
    </HBox>

    <!-- Table + bottom bar -->
    <VBox styleClass="table-card" VBox.vgrow="ALWAYS" spacing="0.0">

        <TableView fx:id="userTable" VBox.vgrow="ALWAYS" styleClass="table-view">
            <columns>
                <TableColumn fx:id="colSelect"  text=""         prefWidth="38.0"  maxWidth="38.0"/>
                <TableColumn fx:id="colId"      text="#"        prefWidth="55.0"/>
                <TableColumn fx:id="colName"    text="Full Name" prefWidth="180.0"/>
                <TableColumn fx:id="colEmail"   text="Email"    prefWidth="210.0"/>
                <TableColumn fx:id="colStatus"  text="Status"   prefWidth="110.0"/>
                <TableColumn fx:id="colPlan"    text="Plan"     prefWidth="105.0"/>
                <TableColumn fx:id="colPremium" text="Premium"  prefWidth="90.0"/>
                <TableColumn fx:id="colJoined"  text="Joined"   prefWidth="130.0"/>
                <TableColumn fx:id="colActions" text="Actions"  prefWidth="195.0"/>
            </columns>
            <placeholder>
                <Label text="No users match your search" styleClass="page-subtitle"/>
            </placeholder>
        </TableView>

        <!-- Pagination / bulk actions bar -->
        <HBox styleClass="pagination-bar" alignment="CENTER_LEFT" spacing="10.0">
            <Label fx:id="countLabel" text="Loading…" styleClass="count-label"/>
            <Region HBox.hgrow="ALWAYS"/>

            <!-- Bulk actions -->
            <Label text="Bulk:" styleClass="count-label"/>
            <Button fx:id="bulkActivateBtn" text="Activate"
                    styleClass="btn-success,btn-sm"
                    onAction="#handleBulkActivate" disable="true"/>
            <Button fx:id="bulkSuspendBtn"  text="Suspend"
                    styleClass="btn-warning,btn-sm"
                    onAction="#handleBulkSuspend"  disable="true"/>
            <Button fx:id="bulkDeleteBtn"   text="Delete"
                    styleClass="btn-danger,btn-sm"
                    onAction="#handleBulkDelete"   disable="true"/>

            <Separator orientation="VERTICAL"/>

            <!-- Pagination -->
            <Button fx:id="prevBtn" text="◀ Prev"
                    styleClass="btn-outline-muted,btn-sm" onAction="#handlePrevPage"/>
            <Label fx:id="pageLabel" text="Page 1 of 1" styleClass="count-label"/>
            <Button fx:id="nextBtn" text="Next ▶"
                    styleClass="btn-outline-muted,btn-sm" onAction="#handleNextPage"/>
        </HBox>
    </VBox>
</VBox>
