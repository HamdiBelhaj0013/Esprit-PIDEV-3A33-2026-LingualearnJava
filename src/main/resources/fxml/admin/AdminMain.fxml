<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.controller.admin.AdminMainController"
            prefWidth="1200.0" prefHeight="740.0"
            styleClass="admin-root"
            stylesheets="@../../css/admin.css">

    <!-- ── LEFT SIDEBAR ──────────────────────── -->
    <left>
        <VBox styleClass="sidebar" spacing="0.0">

            <Label text="LinguaLearn" styleClass="sidebar-brand"/>
            <Label text="NAVIGATION" styleClass="sidebar-section"/>

            <Button fx:id="btnDashboard" text="  Dashboard"
                    styleClass="sidebar-item" onAction="#showDashboard"
                    maxWidth="Infinity"/>
            <Button fx:id="btnUsers" text="  Users"
                    styleClass="sidebar-item" onAction="#showUsers"
                    maxWidth="Infinity"/>

            <Label text="COMING SOON" styleClass="sidebar-section"/>
            <Button text="  Courses" styleClass="sidebar-item"
                    disable="true" maxWidth="Infinity"/>
            <Button text="  Forum" styleClass="sidebar-item"
                    disable="true" maxWidth="Infinity"/>
            <Button text="  Tests" styleClass="sidebar-item"
                    disable="true" maxWidth="Infinity"/>
            <Button text="  Reports" styleClass="sidebar-item"
                    disable="true" maxWidth="Infinity"/>

            <Region VBox.vgrow="ALWAYS"/>
        </VBox>
    </left>

    <!-- ── MAIN AREA (top bar + content) ─────── -->
    <center>
        <VBox>
            <!-- Top bar -->
            <HBox styleClass="admin-topbar" alignment="CENTER_LEFT" spacing="12.0">
                <Label fx:id="topbarTitle" text="Dashboard" styleClass="topbar-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="adminNameLabel" text="Admin" styleClass="topbar-admin-name"/>
                <Button text="Logout" styleClass="topbar-logout" onAction="#handleLogout"/>
            </HBox>

            <!-- Dynamic content pane -->
            <StackPane fx:id="contentArea" VBox.vgrow="ALWAYS" styleClass="content-area"/>
        </VBox>
    </center>
</BorderPane>
