<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.controller.PlatformLanguageController"
            fitToWidth="true"
            fitToHeight="true"
            hbarPolicy="NEVER"
            styleClass="scroll-pane">

    <content>
        <VBox spacing="20" styleClass="page-container" VBox.vgrow="ALWAYS">
            <padding>
                <Insets top="24" right="28" bottom="28" left="28"/>
            </padding>

            <!-- ===== BREADCRUMB ===== -->
            <HBox styleClass="breadcrumb-bar" spacing="4">
                <Label text="Dashboard" styleClass="breadcrumb-item"/>
                <Label text="/" styleClass="breadcrumb-sep"/>
                <Label text="Pedagogical Content" styleClass="breadcrumb-item"/>
                <Label text="/" styleClass="breadcrumb-sep"/>
                <Label text="Languages" styleClass="breadcrumb-item-active"/>
            </HBox>

            <!-- ===== PAGE HEADER ===== -->
            <HBox alignment="CENTER_LEFT" spacing="12">
                <VBox spacing="3">
                    <Label text="Languages" styleClass="page-title"/>
                    <Label text="Manage platform supported languages" styleClass="page-subtitle"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="+ New Language" onAction="#showAddForm" styleClass="btn-primary"/>
            </HBox>

            <!-- ===== ADD / EDIT FORM PANEL (hidden by default via fx:id) ===== -->
            <VBox fx:id="formPanel" styleClass="form-panel" spacing="14" managed="false" visible="false">
                <HBox alignment="CENTER_LEFT">
                    <Label fx:id="formPanelTitle" text="Add New Language" styleClass="form-panel-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="✕" onAction="#hideForm" styleClass="btn-secondary"/>
                </HBox>

                <Separator/>

                <HBox spacing="16">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Language Name" styleClass="form-label"/>
                        <TextField fx:id="txtName" promptText="e.g. French"/>
                    </VBox>
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="ISO Code" styleClass="form-label"/>
                        <TextField fx:id="txtCode" promptText="e.g. fr"/>
                    </VBox>
                </HBox>

                <VBox spacing="4">
                    <Label text="Flag URL (emoji or image URL)" styleClass="form-label"/>
                    <TextField fx:id="txtFlagUrl" promptText="e.g. 🇫🇷  or  https://..."/>
                </VBox>

                <CheckBox fx:id="chkEnabled" text="Enable this language"/>

                <HBox spacing="10">
                    <Button text="💾  Save" onAction="#addLanguage" styleClass="btn-success"/>
                    <Button text="✏  Update" onAction="#updateLanguage" styleClass="btn-warning"/>
                    <Button text="🗑  Delete" onAction="#deleteLanguage" styleClass="btn-danger"/>
                    <Button text="Reset" onAction="#resetForm" styleClass="btn-secondary"/>
                </HBox>
            </VBox>

            <!-- ===== SEARCH + FILTER BAR ===== -->
            <VBox styleClass="search-bar-box" spacing="0">
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <TextField fx:id="txtSearchLanguage" promptText="🔍  Search by name or code..." HBox.hgrow="ALWAYS"/>
                    <ComboBox fx:id="cbFilterEnabled" promptText="Status" prefWidth="150"/>
                    <ComboBox fx:id="cbSortLanguage" promptText="Sort by" prefWidth="150"/>
                </HBox>
            </VBox>

            <!-- ===== LANGUAGE CARDS GRID ===== -->
            <VBox spacing="0" styleClass="card">
                <HBox styleClass="card-header" alignment="CENTER_LEFT">
                    <Label fx:id="lblAllLanguages" text="All Languages" styleClass="card-header-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblLangCount" text="0 languages" styleClass="badge-gray"/>
                </HBox>
                <VBox styleClass="card-body" spacing="0">
                    <!-- Cards are injected here programmatically -->
                    <FlowPane fx:id="langCardsPane" hgap="14" vgap="14" prefWrapLength="900"/>
                    <!-- Empty state -->
                    <VBox fx:id="emptyState" alignment="CENTER" spacing="8" prefHeight="120" managed="false" visible="false">
                        <Label text="🌍" style="-fx-font-size:36px;"/>
                        <Label text="No languages found" style="-fx-font-size:14px; -fx-text-fill:#94a3b8; -fx-font-weight:bold;"/>
                    </VBox>
                </VBox>
            </VBox>

            <!-- HIDDEN TABLE (used by controller logic — not displayed) -->
            <!-- We keep the TableView but collapse it so the controller still works -->
            <VBox managed="false" visible="false">
                <?import javafx.scene.control.TableView?>
                <?import javafx.scene.control.TableColumn?>
            </VBox>

            <!-- ===== FOOTER ===== -->
            <HBox>
                <Label text="© 2026 LinguaLearn. All rights reserved." styleClass="footer"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="LinguaLearn Admin v1.0" styleClass="footer"/>
            </HBox>

        </VBox>
    </content>
</ScrollPane>
