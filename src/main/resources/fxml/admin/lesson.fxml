<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.controller.LessonController"
            fitToWidth="true"
            fitToHeight="true"
            hbarPolicy="NEVER"
            styleClass="scroll-pane">

    <content>
        <VBox spacing="20" styleClass="page-container" VBox.vgrow="ALWAYS">
            <padding>
                <Insets top="24" right="28" bottom="28" left="28"/>
            </padding>

            <!-- ===== BREADCRUMB ===== -->
            <HBox styleClass="breadcrumb-bar" spacing="4">
                <Label text="Dashboard" styleClass="breadcrumb-item"/>
                <Label text="/" styleClass="breadcrumb-sep"/>
                <Label text="Pedagogical Content" styleClass="breadcrumb-item"/>
                <Label text="/" styleClass="breadcrumb-sep"/>
                <Label text="Lessons" styleClass="breadcrumb-item-active"/>
            </HBox>

            <!-- ===== PAGE HEADER ===== -->
            <HBox alignment="CENTER_LEFT" spacing="12">
                <VBox spacing="3">
                    <Label text="Lessons" styleClass="page-title"/>
                    <Label text="Manage lessons inside courses" styleClass="page-subtitle"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="+ New Lesson" onAction="#showAddLessonForm" styleClass="btn-primary"/>
            </HBox>

            <!-- ===== FORM PANEL ===== -->
            <VBox fx:id="formPanel" styleClass="form-panel" spacing="14" managed="false" visible="false">
                <HBox alignment="CENTER_LEFT">
                    <Label fx:id="formPanelTitle" text="Add New Lesson" styleClass="form-panel-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="✕" onAction="#hideForm" styleClass="btn-secondary"/>
                </HBox>

                <Separator/>

                <HBox spacing="16">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Lesson Title" styleClass="form-label"/>
                        <TextField fx:id="txtTitle" promptText="e.g. Les Salutations"/>
                    </VBox>
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="XP Reward" styleClass="form-label"/>
                        <TextField fx:id="txtXpReward" promptText="e.g. 20"/>
                    </VBox>
                </HBox>

                <VBox spacing="4">
                    <Label text="Course" styleClass="form-label"/>
                    <ComboBox fx:id="cbCourse" promptText="Select course" maxWidth="Infinity"/>
                </VBox>

                <VBox spacing="4">
                    <Label text="Content" styleClass="form-label"/>
                    <TextArea fx:id="txtContent" promptText="Lesson content..." prefRowCount="3"/>
                </VBox>

                <HBox spacing="16">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Vocabulary Data (JSON)" styleClass="form-label"/>
                        <TextArea fx:id="txtVocabularyData" promptText='["word1","word2"]' prefRowCount="2"/>
                    </VBox>
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Grammar Data (JSON)" styleClass="form-label"/>
                        <TextArea fx:id="txtGrammarData" promptText='{"grammar":"present"}' prefRowCount="2"/>
                    </VBox>
                </HBox>

                <HBox spacing="16">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Video File Name" styleClass="form-label"/>
                        <TextField fx:id="txtVideoName" promptText="video.mp4"/>
                    </VBox>
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Thumbnail Name" styleClass="form-label"/>
                        <TextField fx:id="txtThumbName" promptText="thumb.jpg"/>
                    </VBox>
                </HBox>

                <HBox spacing="16">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Resource Name" styleClass="form-label"/>
                        <TextField fx:id="txtResourceName" promptText="resource.pdf"/>
                    </VBox>
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Updated At" styleClass="form-label"/>
                        <DatePicker fx:id="dpUpdatedAt" maxWidth="Infinity"/>
                    </VBox>
                </HBox>

                <HBox spacing="10">
                    <Button text="💾  Add Lesson" onAction="#addLesson" styleClass="btn-success"/>
                    <Button text="✏  Update" onAction="#updateLesson" styleClass="btn-warning"/>
                    <Button text="🗑  Delete" onAction="#deleteLesson" styleClass="btn-danger"/>
                    <Button text="Reset" onAction="#resetForm" styleClass="btn-secondary"/>
                </HBox>
            </VBox>

            <!-- ===== SEARCH + FILTER ===== -->
            <VBox styleClass="search-bar-box">
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <TextField fx:id="txtSearchLesson" promptText="🔍  Search by title..." HBox.hgrow="ALWAYS"/>
                    <ComboBox fx:id="cbFilterCourse" promptText="Course" prefWidth="180"/>
                    <ComboBox fx:id="cbSortLesson" promptText="Sort by" prefWidth="160"/>
                </HBox>
            </VBox>

            <!-- ===== LESSONS TABLE ===== -->
            <VBox spacing="0" styleClass="card" VBox.vgrow="ALWAYS">
                <HBox styleClass="card-header" alignment="CENTER_LEFT">
                    <Label text="All Lessons" styleClass="card-header-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                </HBox>
                <VBox styleClass="card-body" spacing="0" VBox.vgrow="ALWAYS">
                    <TableView fx:id="tableLessons" prefHeight="-1" minHeight="120" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colId"        text="ID"         prefWidth="60"/>
                            <TableColumn fx:id="colTitle"     text="TITLE"      prefWidth="280"/>
                            <TableColumn fx:id="colXpReward"  text="XP"         prefWidth="90"/>
                            <TableColumn fx:id="colCourseId"  text="COURSE ID"  prefWidth="110"/>
                            <TableColumn fx:id="colUpdatedAt" text="UPDATED AT" prefWidth="160"/>
                        </columns>
                    </TableView>
                </VBox>
            </VBox>

            <!-- ===== FOOTER ===== -->
            <HBox>
                <Label text="© 2026 LinguaLearn. All rights reserved." styleClass="footer"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="LinguaLearn Admin v1.0" styleClass="footer"/>
            </HBox>

        </VBox>
    </content>
</ScrollPane>
