<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.controller.admin.StatsController"
      styleClass="dialog-root"
      stylesheets="@../../css/admin.css"
      minWidth="380.0" spacing="0.0">

    <!-- Header -->
    <VBox spacing="4.0">
        <padding>
            <Insets top="20.0" right="24.0" bottom="14.0" left="24.0"/>
        </padding>
        <Label text="Edit Learning Stats" styleClass="dialog-title"/>
        <Label fx:id="userNameLabel" text="" styleClass="page-subtitle"/>
    </VBox>
    <Separator/>

    <!-- Body -->
    <VBox spacing="16.0">
        <padding>
            <Insets top="20.0" right="24.0" bottom="20.0" left="24.0"/>
        </padding>

        <!-- Current stats (read-only) -->
        <VBox spacing="6.0">
            <Label text="Current Values" styleClass="form-section-title"/>
            <HBox spacing="8.0">
                <Label text="XP:"      styleClass="info-label"/>
                <Label fx:id="currentXpLabel" styleClass="info-value"/>
            </HBox>
            <HBox spacing="8.0">
                <Label text="Words:"   styleClass="info-label"/>
                <Label fx:id="currentWordsLabel" styleClass="info-value"/>
            </HBox>
            <HBox spacing="8.0">
                <Label text="Minutes:" styleClass="info-label"/>
                <Label fx:id="currentMinutesLabel" styleClass="info-value"/>
            </HBox>
        </VBox>

        <Separator/>

        <!-- Editable fields -->
        <VBox spacing="10.0">
            <Label text="New Values" styleClass="form-section-title"/>

            <HBox spacing="12.0" alignment="CENTER_LEFT">
                <Label text="Total XP" styleClass="form-label" prefWidth="130.0"/>
                <Spinner fx:id="xpSpinner" prefWidth="160.0" styleClass="spinner"
                         editable="true"/>
            </HBox>
            <HBox spacing="12.0" alignment="CENTER_LEFT">
                <Label text="Words Learned" styleClass="form-label" prefWidth="130.0"/>
                <Spinner fx:id="wordsSpinner" prefWidth="160.0" styleClass="spinner"
                         editable="true"/>
            </HBox>
            <HBox spacing="12.0" alignment="CENTER_LEFT">
                <Label text="Minutes Studied" styleClass="form-label" prefWidth="130.0"/>
                <Spinner fx:id="minutesSpinner" prefWidth="160.0" styleClass="spinner"
                         editable="true"/>
            </HBox>
        </VBox>

        <Label fx:id="errorLabel" styleClass="form-error" visible="false" managed="false"/>
    </VBox>

    <Separator/>

    <!-- Footer -->
    <HBox styleClass="dialog-footer" alignment="CENTER_RIGHT" spacing="10.0">
        <Button text="Cancel" styleClass="btn-outline-muted" onAction="#handleCancel"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Save Stats" styleClass="btn-primary" onAction="#handleSave"
                defaultButton="true"/>
    </HBox>
</VBox>
