<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox minWidth="480.0" spacing="0.0" styleClass="dialog-root" stylesheets="@../../css/admin.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controller.admin.UserFormController">

    <!-- Header -->
    <VBox spacing="4.0">
        <padding>
            <Insets bottom="16.0" left="24.0" right="24.0" top="20.0" />
        </padding>
        <Label fx:id="dialogTitle" styleClass="dialog-title" text="Create User" />
        <Label fx:id="dialogSubtitle" styleClass="page-subtitle" text="Fill in the details below" />
    </VBox>
    <Separator />

    <!-- Scrollable form body -->
    <ScrollPane fitToWidth="true" styleClass="scroll-pane" VBox.vgrow="ALWAYS">
        <VBox spacing="14.0">
            <padding>
                <Insets bottom="20.0" left="24.0" right="24.0" top="20.0" />
            </padding>

            <!-- First Name -->
            <VBox spacing="4.0">
                <Label styleClass="form-label" text="First Name *" />
                <TextField fx:id="firstNameField" maxWidth="Infinity" promptText="e.g. John" styleClass="form-input" />
                <Label fx:id="firstNameError" managed="false" styleClass="form-error" visible="false" />
            </VBox>

            <!-- Last Name -->
            <VBox spacing="4.0">
                <Label styleClass="form-label" text="Last Name *" />
                <TextField fx:id="lastNameField" maxWidth="Infinity" promptText="e.g. Doe" styleClass="form-input" />
                <Label fx:id="lastNameError" managed="false" styleClass="form-error" visible="false" />
            </VBox>

            <!-- Email -->
            <VBox spacing="4.0">
                <Label styleClass="form-label" text="Email Address *" />
                <TextField fx:id="emailField" maxWidth="Infinity" promptText="john@example.com" styleClass="form-input" />
                <Label fx:id="emailError" managed="false" styleClass="form-error" visible="false" />
            </VBox>

            <!-- Password -->
            <VBox spacing="4.0">
                <Label fx:id="passwordLabel" styleClass="form-label" text="Password *" />
                <PasswordField fx:id="passwordField" maxWidth="Infinity" promptText="Min. 6 characters" styleClass="form-input" />
                <Label fx:id="passwordError" managed="false" styleClass="form-error" visible="false" />
            </VBox>

            <!-- Confirm Password -->
            <VBox spacing="4.0">
                <Label styleClass="form-label" text="Confirm Password" />
                <PasswordField fx:id="confirmField" maxWidth="Infinity" promptText="Repeat password" styleClass="form-input" />
                <Label fx:id="confirmError" managed="false" styleClass="form-error" visible="false" />
            </VBox>

            <!-- Status (edit only) -->
            <VBox fx:id="statusRow" managed="false" spacing="4.0" visible="false">
                <Label styleClass="form-label" text="Status" />
                <ChoiceBox fx:id="statusChoice" maxWidth="Infinity" prefWidth="220.0" />
                <Label fx:id="statusError" managed="false" styleClass="form-error" visible="false" />
            </VBox>

            <!-- Roles -->
            <VBox spacing="6.0">
                <Label styleClass="form-label" text="Roles" />
                <CheckBox fx:id="roleUser" disable="true" text="ROLE_USER (always included)" />
                <CheckBox fx:id="roleAdmin" text="ROLE_ADMIN" />
                <CheckBox fx:id="roleTeacher" text="ROLE_TEACHER" textFill="RED" />
            </VBox>

            <!-- Global error -->
            <Label fx:id="globalError" managed="false" styleClass="form-error" visible="false" wrapText="true" />
        </VBox>
    </ScrollPane>

    <Separator />

    <!-- Footer buttons -->
    <HBox alignment="CENTER_RIGHT" spacing="10.0" styleClass="dialog-footer">
        <Button onAction="#handleCancel" styleClass="btn-outline-muted" text="Cancel" />
        <Region HBox.hgrow="ALWAYS" />
        <Button fx:id="saveBtn" defaultButton="true" onAction="#handleSave" styleClass="btn-primary" text="Save" />
    </HBox>
</VBox>
