<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<StackPane prefHeight="480.0" prefWidth="480.0" styleClass="auth-root"
           stylesheets="@../css/style.css"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="org.example.controller.user.user_managment.VerifyOTPController">

    <VBox alignment="TOP_CENTER" maxWidth="420.0" styleClass="auth-card" spacing="16.0">

        <padding>
            <Insets bottom="40.0" left="40.0" right="40.0" top="36.0" />
        </padding>

        <!-- ── Logo accent ──────────────────────── -->
        <HBox alignment="CENTER">
            <Label styleClass="auth-logo-pill">
                <graphic><FontIcon iconLiteral="mdi2s-shield-check-outline" iconSize="28" styleClass="auth-logo-icon"/></graphic>
            </Label>
        </HBox>

        <!-- ── Title ───────────────────────────────── -->
        <Label styleClass="app-title" text="Enter Reset Code" />
        <Label fx:id="subtitleLabel" styleClass="subtitle"
               text="We sent a 6-digit code to your email" />

        <!-- ── OTP field ────────────────────────────── -->
        <VBox alignment="CENTER" spacing="4.0">
            <Label styleClass="field-label" text="6-Digit Code" />
            <TextField fx:id="otpField" maxWidth="160.0" promptText="000000"
                       styleClass="input-field, otp-field" />
        </VBox>

        <!-- ── Error message ───────────────────────── -->
        <Label fx:id="errorLabel" managed="false" maxWidth="340.0"
               styleClass="error-label" visible="false" wrapText="true" />

        <!-- ── Success message (resend) ───────────── -->
        <Label fx:id="successLabel" managed="false" maxWidth="340.0"
               styleClass="success-label" visible="false" wrapText="true" />

        <!-- ── Verify button ────────────────────────── -->
        <Button defaultButton="true" maxWidth="Infinity"
                onAction="#handleVerify" styleClass="login-btn" text="Verify Code">
            <VBox.margin>
                <Insets top="4.0" />
            </VBox.margin>
        </Button>

        <!-- ── Resend / Back ───────────────────────── -->
        <Button alignment="CENTER" maxWidth="Infinity" onAction="#handleResend"
                styleClass="link-btn" text="Resend Code" />
        <Button alignment="CENTER" maxWidth="Infinity" onAction="#handleBackToLogin"
                styleClass="link-btn" text="Back to Login" />

    </VBox>
</StackPane>
