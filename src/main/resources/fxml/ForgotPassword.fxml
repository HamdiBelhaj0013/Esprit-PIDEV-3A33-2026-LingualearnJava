<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="520.0" prefWidth="600.0" styleClass="root-pane"
           stylesheets="@../css/style.css"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="org.example.controller.ForgotPasswordController">

    <VBox alignment="TOP_CENTER" maxWidth="652.0" prefHeight="520.0" prefWidth="652.0"
          spacing="18.0" styleClass="login-card">

        <padding>
            <Insets bottom="44.0" left="44.0" right="44.0" top="44.0" />
        </padding>

        <!-- ── Title ───────────────────────────────── -->
        <Label styleClass="app-title" text="Reset Password" />
        <Label styleClass="subtitle" text="Enter your email to receive a reset code" />

        <!-- ── Email ───────────────────────────────── -->
        <VBox spacing="4.0">
            <Label styleClass="field-label" text="Email" />
            <TextField fx:id="emailField" promptText="Email address" styleClass="input-field" />
        </VBox>

        <!-- ── Error / Success messages ────────────── -->
        <Label fx:id="errorLabel" managed="false" maxWidth="400.0"
               styleClass="error-label" visible="false" wrapText="true" />
        <Label fx:id="successLabel" managed="false" maxWidth="400.0"
               styleClass="success-label" visible="false" wrapText="true" />

        <!-- ── Send Code button ─────────────────────── -->
        <Button fx:id="sendButton" defaultButton="true" maxWidth="Infinity"
                onAction="#handleSendCode" styleClass="login-btn" text="Send Reset Code">
            <VBox.margin>
                <Insets top="6.0" />
            </VBox.margin>
        </Button>

        <!-- ── Back to Login ───────────────────────── -->
        <Button alignment="CENTER" maxWidth="Infinity" onAction="#handleBackToLogin"
                styleClass="link-btn" text="Back to Login" />

    </VBox>
</StackPane>
