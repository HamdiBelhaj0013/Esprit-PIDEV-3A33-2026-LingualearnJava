<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<StackPane prefHeight="480.0" prefWidth="480.0" styleClass="auth-root"
           stylesheets="@../css/style.css"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="org.example.controller.user.user_managment.ForgotPasswordController">

    <VBox alignment="TOP_CENTER" maxWidth="420.0" styleClass="auth-card" spacing="16.0">

        <padding>
            <Insets bottom="40.0" left="40.0" right="40.0" top="36.0" />
        </padding>

        <!-- ── Logo accent ──────────────────────── -->
        <HBox alignment="CENTER">
            <Label styleClass="auth-logo-pill">
                <graphic><FontIcon iconLiteral="mdi2l-lock-reset" iconSize="28" styleClass="auth-logo-icon"/></graphic>
            </Label>
        </HBox>

        <!-- ── Title ───────────────────────────────── -->
        <Label styleClass="app-title" text="Reset Password" />
        <Label styleClass="subtitle" text="Enter your email to receive a reset code" />

        <!-- ── Email ───────────────────────────────── -->
        <VBox spacing="4.0">
            <Label styleClass="field-label" text="Email" />
            <TextField fx:id="emailField" promptText="Email address" styleClass="input-field" />
        </VBox>

        <!-- ── Error / Success messages ────────────── -->
        <Label fx:id="errorLabel" managed="false" maxWidth="340.0"
               styleClass="error-label" visible="false" wrapText="true" />
        <Label fx:id="successLabel" managed="false" maxWidth="340.0"
               styleClass="success-label" visible="false" wrapText="true" />

        <!-- ── Send Code button ─────────────────────── -->
        <Button fx:id="sendButton" defaultButton="true" maxWidth="Infinity"
                onAction="#handleSendCode" styleClass="login-btn" text="Send Reset Code">
            <VBox.margin>
                <Insets top="4.0" />
            </VBox.margin>
        </Button>

        <!-- ── Back to Login ───────────────────────── -->
        <Button alignment="CENTER" maxWidth="Infinity" onAction="#handleBackToLogin"
                styleClass="link-btn" text="Back to Login" />

    </VBox>
</StackPane>
