<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.controllers.QuizController"
      stylesheets="@styles.css"
      prefWidth="1200" prefHeight="800">

    <fx:include fx:id="sidebar" source="Sidebar.fxml"/>

    <VBox HBox.hgrow="ALWAYS" spacing="0">
        <!-- TOP HEADER -->
        <HBox alignment="CENTER_LEFT" styleClass="top-header">
            <VBox spacing="3">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <FontIcon iconLiteral="fas-brain" iconSize="22" iconColor="#1e293b"/>
                    <Label fx:id="headerTitle" text="Quiz Management" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                </HBox>
                <Label fx:id="headerSubtitle" text="Create, manage and organize your linguistic quizzes" style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="btnAddNew" onAction="#goToCreateForm" styleClass="btn-primary">
                <graphic>
                    <HBox spacing="8" alignment="CENTER">
                        <FontIcon iconLiteral="fas-plus" iconSize="12" iconColor="white"/>
                        <Label text="New Quiz" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                    </HBox>
                </graphic>
            </Button>
        </HBox>

        <ScrollPane fitToWidth="true" styleClass="scroll-pane-transparent" VBox.vgrow="ALWAYS">
            <VBox spacing="25" style="-fx-padding: 30;">

                <!-- STAT CARDS ROW -->
                <HBox spacing="20">
                    <HBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="16" alignment="CENTER_LEFT">
                        <StackPane styleClass="stat-icon-purple">
                            <FontIcon iconLiteral="fas-layer-group" iconSize="20" iconColor="#0d6efd"/>
                        </StackPane>
                        <VBox spacing="2">
                            <Label fx:id="statTotal" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                            <Label text="Total Quizzes" style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
                        </VBox>
                    </HBox>
                    <HBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="16" alignment="CENTER_LEFT">
                        <StackPane styleClass="stat-icon-green">
                            <FontIcon iconLiteral="fas-check-circle" iconSize="20" iconColor="#22c55e"/>
                        </StackPane>
                        <VBox spacing="2">
                            <Label fx:id="statActive" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #22c55e;"/>
                            <Label text="Active" style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
                        </VBox>
                    </HBox>
                    <HBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="16" alignment="CENTER_LEFT">
                        <StackPane styleClass="stat-icon-orange">
                            <FontIcon iconLiteral="fas-pause-circle" iconSize="20" iconColor="#f59e0b"/>
                        </StackPane>
                        <VBox spacing="2">
                            <Label fx:id="statInactive" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #f59e0b;"/>
                            <Label text="Inactive" style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
                        </VBox>
                    </HBox>
                </HBox>

                <!-- FILTERS BAR -->
                <HBox spacing="15" alignment="CENTER_LEFT" styleClass="filter-bar" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 12;">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="SEARCH" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #94a3b8;"/>
                        <TextField fx:id="searchField" promptText="Search quizzes..." styleClass="text-field-modern"/>
                    </VBox>

                    <VBox spacing="6">
                        <Label text="STATUS" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #94a3b8;"/>
                        <ComboBox fx:id="filterStatus" prefWidth="150" styleClass="text-field-modern"/>
                    </VBox>

                    <VBox spacing="6">
                        <Label text="LESSON" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #94a3b8;"/>
                        <ComboBox fx:id="filterLesson" prefWidth="180" styleClass="text-field-modern"/>
                    </VBox>

                    <VBox spacing="6">
                        <Label text="SORT BY" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #94a3b8;"/>
                        <ComboBox fx:id="comboSort" prefWidth="150" styleClass="text-field-modern"/>
                    </VBox>

                    <VBox spacing="6" alignment="BOTTOM_CENTER">
                        <Button onAction="#handleReset" styleClass="btn-outline" prefHeight="45">
                            <graphic>
                                <FontIcon iconLiteral="fas-sync-alt" iconSize="14"/>
                            </graphic>
                        </Button>
                    </VBox>
                </HBox>

                <!-- GRID OF CARDS -->
                <FlowPane fx:id="quizGrid" hgap="25" vgap="25" alignment="TOP_LEFT"/>

                <HBox alignment="CENTER_LEFT" style="-fx-padding: 10 0 30 0;">
                    <Label fx:id="labelTotalCount" text="Showing 0 quizzes" style="-fx-text-fill: #94a3b8; -fx-font-size: 12px;"/>
                </HBox>
            </VBox>
        </ScrollPane>
    </VBox>
</HBox>
