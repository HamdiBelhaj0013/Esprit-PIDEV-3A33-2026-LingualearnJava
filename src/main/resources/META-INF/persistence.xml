<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence" version="3.0">

    <persistence-unit name="lingualearn" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <class>org.example.entity.User</class>
        <class>org.example.entity.LearningStats</class>

        <properties>
            <property name="jakarta.persistence.jdbc.driver"
                      value="com.mysql.cj.jdbc.Driver"/>


            <property name="jakarta.persistence.jdbc.url"
                      value="jdbc:mysql://127.0.0.1:3306/1lingualearn_db?serverTimezone=UTC&amp;useSSL=false&amp;allowPublicKeyRetrieval=true"/>
            <property name="jakarta.persistence.jdbc.user"
                      value="root"/>
            <property name="jakarta.persistence.jdbc.password"
                      value=""/>

            <!-- "none" = never touch schema, read your existing Symfony data -->
            <property name="hibernate.hbm2ddl.auto"  value="none"/>
            <property name="hibernate.dialect"        value="org.hibernate.dialect.MySQLDialect"/>
            <property name="hibernate.show_sql"       value="false"/>
        </properties>
    </persistence-unit>

</persistence>
